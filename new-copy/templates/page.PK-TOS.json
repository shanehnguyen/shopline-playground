      "blocks": {
        "17750890298386d273a1": {
          "type": "terms_section",
          "settings": {
            "heading": "1. Acceptance of Terms",
            "body": "By accessing and using PK Cabinet's website, you accept and agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our services or access our website."
          },
          "blockId": "17750890298386d273a1"
        },
        "17750890298389052c14": {
          "type": "terms_section",
          "settings": {
            "heading": "2. Use of Website",
            "body": "The website is provided for personal and commercial use related to purchasing our products. Prohibited activities include data scraping, unauthorized access to our systems, and any malicious use that interferes with website functionality. All content, including images, text, and designs, are the intellectual property of PK Cabinet."
          },
          "blockId": "17750890298389052c14"
        },
        "1775089029838a7aab2b": {
          "type": "terms_section",
          "settings": {
            "heading": "3. Product Information",
            "body": "We strive for accuracy in product descriptions and pricing; however, errors may occur. We reserve the right to modify prices, specifications, and availability without prior notice. Please note that actual product colors and finishes may vary slightly from what is displayed on your screen due to monitor settings and natural wood characteristics."
          },
          "blockId": "1775089029838a7aab2b"
        },
        "1775089029838ad700bf": {
          "type": "terms_section",
          "settings": {
            "heading": "4. Orders and Payment",
            "body": "Order acceptance occurs when we send a confirmation email. We reserve the right to refuse any order. We accept major credit cards and other secure payment methods as specified at checkout. All prices are in USD. We reserve the right to cancel orders due to pricing errors."
          },
          "blockId": "1775089029838ad700bf"
        },
        "1775089029838ec70475": {
          "type": "terms_section",
          "settings": {
            "heading": "5. Shipping and Delivery",
            "body": "Delivery timeframes are estimates. Please refer to our Shipping and Delivery page for details. Risk of loss and title for products pass to you upon delivery to the carrier or delivery location. Customers are required to inspect all items upon receipt and report any damage within 48 hours."
          },
          "blockId": "1775089029838ec70475"
        },
        "177508902983814b207f": {
          "type": "terms_section",
          "settings": {
            "heading": "6. Returns and Refunds",
            "body": "Our return process is governed by our Refund Policy. Generally, requests must be submitted within 14 days of receipt for unused and unassembled items."
          },
          "blockId": "177508902983814b207f"
        },
        "17750890298380103264": {
          "type": "terms_section",
          "settings": {
            "heading": "7. Warranty",
            "body": "Products are covered by a limited warranty as detailed on our Guarantee and Warranty page. Liability is limited to the repair or replacement of defective components."
          },
          "blockId": "17750890298380103264"
        },
        "17750890298385b15717": {
          "type": "terms_section",
          "settings": {
            "heading": "8. Limitation of Liability",
            "body": "PK Cabinet shall not be liable for any indirect, incidental, or consequential damages arising from the use of our products. Our maximum liability is limited to the purchase price of the specific product in question."
          },
          "blockId": "17750890298385b15717"
        },
        "17750890298388c72b84": {
          "type": "terms_section",
          "settings": {
            "heading": "9. Dispute Resolution",
            "body": "These terms are governed by the laws of the State of California. Any disputes shall be resolved through binding arbitration in Los Angeles County, California."
          },
          "blockId": "17750890298388c72b84"
        },
        "17750890298383429392": {
          "type": "terms_section",
          "settings": {
            "heading": "10. Changes to Terms",
            "body": "We reserve the right to modify these terms at any time. Continued use of the website following changes constitutes your acceptance of the new terms."
          },
          "blockId": "17750890298383429392"
        }
