 Cabinet 30\"W × 15\"H',\r\n    size:30,\r\n    height:15,\r\n    depth:24,\r\n    sku:\"ICWS-W301524\",\r\n    price:309.82,\r\n    features:\"2 Doors | 1 Adjustable Shelf\",\r\n    category:\"Wall Cabinet\",\r\n    link:\"https://www.pkcabinet.com/products/white-shaker-30w-×-15h-deep-24-wall-bridge-cabinet-2-doors-1-adjustable-shelf\",\r\n    images:[\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/W301524-white-shaker.jpg?w=1997&h=1997\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/W301524-white-shaker-(2).jpg?w=1997&h=1997\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/W301524-white-shaker-(3).jpg?w=1997&h=1997\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/W301524-SHAKER-SIZE.jpg?w=1200&h=1600\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/-1-9.jpg?w=1200&h=694\"\r\n    ]\r\n  },\r\n    {\r\n    mainTitle:\"Mallorca White Shaker\",\r\n    subTitle:'Blind Corner Base Cabinet 45\"W',\r\n    size:45,\r\n    height:34.5,\r\n    depth:24,\r\n    sku:\"ICWS-BBC45\",\r\n    price:672.21,\r\n    features:\"1 Door | 1 Drawer | 1 Adjustable Shelf\",\r\n    category:\"Base Cabinet\",\r\n    link:\"https://www.pkcabinet.com/products/white-shaker-45w-blind-corner-base-cabinet-1-door-1-drawer-1-adjustable-shelf\",\r\n    images:[\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC45-white-shaker.jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC45-white-shaker-(2).jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC45-white-shaker-(3).jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC42-45-SHAKER-SIZE.jpg?w=1200&h=1600\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/-1-9.jpg?w=1200&h=694\"\r\n    ]\r\n  },\r\n    {\r\n    mainTitle:\"Mallorca White Shaker\",\r\n    subTitle:'Blind Corner Base Cabinet 42\"W',\r\n    size:42,\r\n    height:34.5,\r\n    depth:24,\r\n    sku:\"ICWS-BBC42\",\r\n    price:586.66,\r\n    features:\"1 Door | 1 Drawer | 1 Adjustable Shelf\",\r\n    category:\"Base Cabinet\",\r\n    link:\"https://www.pkcabinet.com/products/white-shaker-42w-blind-corner-base-cabinet-1-door-1-drawer-1-adjustable-shelf\",\r\n    images:[\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC42-white-shaker.jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC42-white-shaker-(2).jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC42-white-shaker-(3).jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC36-42-SHAKER-SIZE.jpg?w=1200&h=1600\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/-1-9.jpg?w=1200&h=694\"\r\n    ]\r\n  }\r\n\r\n];\r\n\r\n// ===============================\r\n// !!!DO NOT EDIT BELOW!!!\r\n// ===============================\r\n\r\nconst grid=document.getElementById(\"collectionGrid\");\r\nconst pagination=document.getElementById(\"pagination\");\r\nconst sizeFilter=document.getElementById(\"sizeFilter\");\r\nconst priceSort=document.getElementById(\"priceSort\");\r\nconst categoryFilter=document.getElementById(\"categoryFilter\");\r\n\r\n// Populate Size Filter\r\nconst uniqueSizes=[...new Set(products.map(p=>p.size))];\r\nuniqueSizes.forEach(size=>{\r\n  const opt=document.createElement(\"option\");\r\n  opt.value=size;\r\n  opt.textContent=size+'\"';\r\n  sizeFilter.appendChild(opt);\r\n});\r\n\r\n// Populate Category Filter\r\nconst uniqueCategories=[...new Set(products.map(p=>p.category))];\r\nuniqueCategories.forEach(cat=>{\r\n  const opt=document.createElement(\"option\");\r\n  opt.value=cat;\r\n  opt.textContent=cat;\r\n  categoryFilter.appendChild(opt);\r\n});\r\n\r\n// Sort products by size ascending on page load\r\nproducts.sort((a,b)=>a.size - b.size);\r\n\r\nlet currentPage=1;\r\nconst perPage=15;\r\n\r\nfunction renderProducts(){\r\n  let filtered=[...products];\r\n\r\n  if(sizeFilter.value!==\"all\"){\r\n    filtered=filtered.filter(p=>p.size==sizeFilter.value);\r\n  }\r\n\r\n  if(categoryFilter.value!==\"all\"){\r\n    filtered=filtered.filter(p=>p.category===categoryFilter.value);\r\n  }\r\n\r\n  if(priceSort.value===\"low\"){\r\n    filtered.sort((a,b)=>a.price-b.price);\r\n  }\r\n\r\n  if(priceSort.value===\"high\"){\r\n    filtered.sort((a,b)=>b.price-a.price);\r\n  }\r\n\r\n  const totalPages=Math.ceil(filtered.length/perPage);\r\n  if(currentPage>totalPages) currentPage=1;\r\n\r\n  const start=(currentPage-1)*perPage;\r\n  const paginated=filtered.slice(start,start+perPage);\r\n\r\n  grid.innerHTML=\"\";\r\n\r\n  paginated.forEach(product=>{\r\n    const card=document.createElement(\"div\");\r\n    card.className=\"card\";\r\n\r\nconst imagesHTML = product.images.map((img,index)=>`\r\n  <img src=\"${img}\" class=\"${index===0?'active':''}\" loading=\"lazy\">\r\n`).join(\"\");\r\n\r\ncard.innerHTML = `\r\n  <div class=\"image-container\">\r\n    ${imagesHTML}\r\n    <div class=\"arrow left\">&#10094;</div>\r\n    <div class=\"arrow right\">&#10095;</div>\r\n  </div>\r\n  <div class=\"card-content\">\r\n    <div class=\"card-title\">\r\n      <span class=\"white-shaker\">${product.mainTitle}</span><br>\r\n      <span class=\"subtitle\">${product.subTitle}</span>\r\n    </div>\r\n    <div class=\"dimensions\"> ${product.size}\" W × ${product.height}\" H × ${product.depth}\" D </div>\r\n    <div class=\"sku-box\">SKU: ${product.sku}</div>\r\n    <div class=\"features\">${product.features}</div>\r\n    <div class=\"price\">\r\n      <div class=\"price\">$${product.price}</div>\r\n    </div>\r\n  </div>\r\n`;\r\n\r\n\r\n    const imgs=card.querySelectorAll(\"img\");\r\n    const left=card.querySelector(\".left\");\r\n    const right=card.querySelector(\".right\");\r\n    const imageBox=card.querySelector(\".image-container\");\r\n\r\n    let index=0;\r\n\r\n    function showImage(i){\r\n      imgs.forEach(img=>img.classList.remove(\"active\"));\r\n      imgs[i].classList.add(\"active\");\r\n    }\r\n\r\n    card.addEventListener(\"mouseenter\",()=>{\r\n      if(imgs.length>1){\r\n        index=1;\r\n        showImage(index);\r\n      }\r\n    });\r\n\r\n    card.addEventListener(\"mouseleave\",()=>{\r\n      index=0;\r\n      showImage(index);\r\n    });\r\n\r\n    left.addEventListener(\"click\",(e)=>{\r\n      e.stopPropagation();\r\n      index=(index-1+imgs.length)%imgs.length;\r\n      showImage(index);\r\n    });\r\n\r\n    right.addEventListener(\"click\",(e)=>{\r\n      e.stopPropagation();\r\n      index=(index+1)%imgs.length;\r\n      showImage(index);\r\n    });\r\n\r\n    imageBox.addEventListener(\"click\",()=>{\r\n      window.open(product.link, \"_blank\");\r\n    });\r\n\r\n    grid.appendChild(card);\r\n  });\r\n\r\n  renderPagination(Math.ceil(filtered.length/perPage));\r\n}\r\n\r\nfunction renderPagination(totalPages){\r\n  pagination.innerHTML=\"\";\r\n  for(let i=1;i<=totalPages;i++){\r\n    const btn=document.createElement(\"div\");\r\n    btn.className=\"page-btn\";\r\n    if(i===currentPage) btn.classList.add(\"active\");\r\n    btn.textContent=i;\r\n    btn.onclick=()=>{\r\n      currentPage=i;\r\n      renderProducts();\r\n      window.scrollTo({top:0,behavior:'smooth'});\r\n    };\r\n    pagination.appendChild(btn);\r\n  }\r\n}\r\n\r\nsizeFilter.addEventListener(\"change\",()=>{currentPage=1; renderProducts();});\r\ncategoryFilter.addEventListener(\"change\",()=>{currentPage=1; renderProducts();});\r\npriceSort.addEventListener(\"change\",()=>{renderProducts();});\r\n\r\n// Initial render\r\nrenderProducts();\r\n\r\n</script>\r\n\r\n</body>\r\n</html>",
