        "174019273298361ad895": {
          "type": "content",
          "blockId": "174019273298361ad895",
          "settings": {
            "title": "Why should I choose a U.S.-based cabinet manufacturer?",
            "desc": "<p>Choosing a domestic manufacturer like PK Cabinet guarantees faster lead times, higher quality control, and no hidden import fees. Our local expertise ensures your cabinets meet American building standards and design preferences.</p>"
          }
        },
        "1740192732983f56ad05": {
          "type": "content",
          "blockId": "1740192732983f56ad05",
          "settings": {
            "title": "How do I know if PK Cabinet is the right supplier for my project?",
            "desc": "<ul>\n<li>Proven Track Record: Trusted by contractors and builders nationwide</li>\n<li>Custom Solutions: Tailored designs for any space or style</li>\n<li>Transparent Pricing: No surprises—just fair, upfront costs</li>\n</ul>"
          }
        },
        "17401927329830876ec5": {
          "type": "content",
          "blockId": "17401927329830876ec5",
          "settings": {
            "title": "What is the typical lead time for cabinet delivery?",
            "desc": "<p>Most orders ship within 3-5 business days for in-stock items, with custom projects taking 2-4 weeks. Expedited options are available.</p>"
          }
        },
        "1740192732983028a2a3": {
          "type": "nav",
          "blockId": "1740192732983028a2a3",
          "settings": {},
          "disabled": true
        },
        "1740192732983b56a0c5": {
          "type": "content",
          "blockId": "1740192732983b56a0c5",
          "settings": {
            "title": "How can I reduce costs without sacrificing quality?",
            "desc": "<ul>\n<li>Opt for standard sizes and finishes</li>\n<li>Plan ahead to avoid rush fees</li>\n<li>Ask about bulk order discounts</li>\n</ul>"
          }
        },
        "17401927329834d63d7c": {
          "type": "content",
          "blockId": "17401927329834d63d7c",
          "settings": {
            "title": "Do the cabinets contain any harmful chemicals?",
            "desc": "No. Our manufacturing process is designed to be as eco-friendly and safe as possible, and our products comply with U.S. TSCA and CARB standards."
          }
        },
        "1740192741680192396f": {
          "type": "nav",
          "settings": {
            "title": "SHIPPING",
            "icon": "check_mark",
            "pc_icon_width": 30,
            "mb_icon_width": 24
          },
          "disabled": true
        },
        "1740192743557ab9d949": {
          "type": "content",
          "settings": {
            "title": "Do you offer any discounts?",
            "desc": "Yes, we offer a variety of discounts. In addition to our promotional activities, for individual customers, each product line comes with attractive discounts. For business customers, we typically provide additional discounts beyond those for individual buyers. If your purchase reaches a certain amount, you may also qualify for even greater savings."
          }
        },
        "1740192745054f5e0460": {
          "type": "content",
          "settings": {
            "title": "Do you offer contractor discounts?",
            "desc": "Yes! We offer special discounts for all contractors, you can find full information about our contractor discount program&nbsp;"
          }
        },
        "1740192747462e221939": {
          "type": "content",
          "settings": {
            "title": "Do you sell custom or semi-custom cabinets?",
            "desc": "All the cabinets we sell on our website are RTA Cabinets, but we also offer customization product lines. Please contact customer support for more information."
          }
        }
      },
