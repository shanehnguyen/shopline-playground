6/BBC42-45-SHAKER-SIZE.jpg?w=1200&h=1600\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/-1-9.jpg?w=1200&h=694\"\r\n    ]\r\n  },\r\n    {\r\n    mainTitle:\"Mallorca White Shaker\",\r\n    subTitle:'Blind Corner Base Cabinet 42\"W',\r\n    size:42,\r\n    height:34.5,\r\n    depth:24,\r\n    sku:\"ICWS-BBC42\",\r\n    price:586.66,\r\n    features:\"1 Door | 1 Drawer | 1 Adjustable Shelf\",\r\n    category:\"Base Cabinet\",\r\n    link:\"https://www.pkcabinet.com/products/white-shaker-42w-blind-corner-base-cabinet-1-door-1-drawer-1-adjustable-shelf\",\r\n    images:[\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC42-white-shaker.jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC42-white-shaker-(2).jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC42-white-shaker-(3).jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC36-42-SHAKER-SIZE.jpg?w=1200&h=1600\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/-1-9.jpg?w=1200&h=694\"\r\n    ]\r\n  },\r\n    {\r\n    mainTitle:\"Mallorca White Shaker\",\r\n    subTitle:'Blind Corner Base Cabinet 42\"W',\r\n    size:42,\r\n    height:34.5,\r\n    depth:24,\r\n    sku:\"ICWS-BBC42\",\r\n    price:586.66,\r\n    features:\"1 Door | 1 Drawer | 1 Adjustable Shelf\",\r\n    category:\"Base Cabinet\",\r\n    link:\"https://www.pkcabinet.com/products/white-shaker-42w-blind-corner-base-cabinet-1-door-1-drawer-1-adjustable-shelf\",\r\n    images:[\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC42-white-shaker.jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC42-white-shaker-(2).jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC42-white-shaker-(3).jpg?w=2000&h=2000\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/BBC36-42-SHAKER-SIZE.jpg?w=1200&h=1600\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/-1-9.jpg?w=1200&h=694\"\r\n    ]\r\n  },\r\n\r\n];\r\n</script>\r\n\r\n<script>\r\n\r\nconst track = document.getElementById(\"track\");\r\n\r\nlet list = [...products, ...products, ...products];\r\n\r\nlist.forEach(product=>{\r\n\r\nconst card=document.createElement(\"div\");\r\ncard.className=\"card\";\r\n\r\n\r\nconst imagesHTML = product.images.map((img,i)=>\r\n`<img src=\"${img}\" class=\"${i===0?'active':''}\">`\r\n).join(\"\");\r\n\r\n\r\ncard.innerHTML = `\r\n\r\n<div class=\"image-container\">\r\n\r\n${imagesHTML}\r\n\r\n<div class=\"arrow left\">&#10094;</div>\r\n<div class=\"arrow right\">&#10095;</div>\r\n\r\n</div>\r\n\r\n<div class=\"card-content\">\r\n\r\n<div class=\"card-title\">\r\n${product.mainTitle}\r\n<div class=\"subtitle\">${product.subTitle}</div>\r\n</div>\r\n\r\n<div class=\"dimensions\">\r\n${product.size}\" W × ${product.height}\" H × ${product.depth}\" D\r\n</div>\r\n\r\n<div class=\"sku-box\">\r\nSKU: ${product.sku}\r\n</div>\r\n\r\n<div class=\"features\">\r\n${product.features}\r\n</div>\r\n\r\n<div class=\"price\">\r\n$${product.price}\r\n</div>\r\n\r\n</div>\r\n\r\n`;\r\n\r\n\r\n// =======================\r\n// IMAGE SWITCH LOGIC (restored)\r\n// =======================\r\n\r\nconst imgs = card.querySelectorAll(\"img\");\r\nconst left = card.querySelector(\".left\");\r\nconst right = card.querySelector(\".right\");\r\nconst imageBox = card.querySelector(\".image-container\");\r\n\r\nlet imgIndex = 0;\r\n\r\nfunction showImage(i){\r\nimgs.forEach(img=>img.classList.remove(\"active\"));\r\nimgs[i].classList.add(\"active\");\r\n}\r\n\r\ncard.addEventListener(\"mouseenter\",()=>{\r\nif(imgs.length>1){\r\nimgIndex=1;\r\nshowImage(imgIndex);\r\n}\r\n});\r\n\r\ncard.addEventListener(\"mouseleave\",()=>{\r\nimgIndex=0;\r\nshowImage(imgIndex);\r\n});\r\n\r\nleft.addEventListener(\"click\",(e)=>{\r\ne.stopPropagation();\r\nimgIndex=(imgIndex-1+imgs.length)%imgs.length;\r\nshowImage(imgIndex);\r\n});\r\n\r\nright.addEventListener(\"click\",(e)=>{\r\ne.stopPropagation();\r\nimgIndex=(imgIndex+1)%imgs.length;\r\nshowImage(imgIndex);\r\n});\r\n\r\nimageBox.addEventListener(\"click\",()=>{\r\nwindow.open(product.link,\"_blank\");\r\n});\r\n\r\ntrack.appendChild(card);\r\n\r\n});\r\n\r\n\r\n// =======================\r\n// INFINITE CAROUSEL\r\n// =======================\r\n\r\nlet index = products.length;\r\nlet isMoving = false;\r\n\r\nfunction update(){\r\n\r\ntrack.style.transform =\r\n`translateX(${index * -284}px)`;\r\n\r\n}\r\n\r\nupdate();\r\n\r\n\r\nfunction move(dir){\r\n\r\nif(isMoving) return;\r\n\r\nisMoving = true;\r\n\r\nindex += dir;\r\n\r\nupdate();\r\n\r\nsetTimeout(()=>{\r\n\r\nif(index >= products.length * 2){\r\n\r\ntrack.style.transition=\"none\";\r\nindex = products.length;\r\nupdate();\r\ntrack.offsetHeight;\r\ntrack.style.transition=\".4s\";\r\n\r\n}\r\n\r\nif(index <= 0){\r\n\r\ntrack.style.transition=\"none\";\r\nindex = products.length;\r\nupdate();\r\ntrack.offsetHeight;\r\ntrack.style.transition=\".4s\";\r\n\r\n}\r\n\r\nisMoving=false;\r\n\r\n},400);\r\n\r\n}\r\n\r\n</script>\r\n\r\n</body>\r\n</html>",
