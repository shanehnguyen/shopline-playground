    "177272815844420726c9": {
      "disabled": false,
      "type": "custom-html",
      "settings": {
        "html": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n   <meta charset=\"UTF-8\">\r\n   <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n   <title>Cabinet Collection</title>\r\n\r\n   <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n\r\n   <style>\r\n      body {\r\n         margin: 0;\r\n         font-family: 'Poppins', sans-serif;\r\n         background: #F3EFE8;\r\n      }\r\n\r\n      .collection-wrapper {\r\n         max-width: 1300px;\r\n         margin: 60px auto;\r\n         padding: 0 80px;\r\n      }\r\n\r\n      .collection-title {\r\n         text-align: center;\r\n         font-size: 30px;\r\n         font-weight: 600;\r\n         margin-bottom: 30px;\r\n      }\r\n\r\n      .controls {\r\n         display: flex;\r\n         justify-content: space-between;\r\n         margin-bottom: 24px;\r\n         flex-wrap: wrap;\r\n         gap: 20px;\r\n      }\r\n\r\n      select {\r\n         padding: 8px 12px;\r\n         border-radius: 8px;\r\n         border: 1px solid #ccc;\r\n         font-family: 'Poppins';\r\n         font-size: 13px;\r\n      }\r\n\r\n      .collection-grid {\r\n         display: grid;\r\n         grid-template-columns: repeat(4, 1fr);\r\n         gap: 24px;\r\n      }\r\n\r\n      @media (max-width:1100px) {\r\n         .collection-grid {\r\n            grid-template-columns: repeat(3, 1fr);\r\n         }\r\n      }\r\n\r\n      @media (max-width:700px) {\r\n         .collection-grid {\r\n            grid-template-columns: repeat(2, 1fr);\r\n         }\r\n      }\r\n\r\n      .card {\r\n         background: #f4f4f4;\r\n         border-radius: 16px;\r\n         overflow: hidden;\r\n         box-shadow: 0 5px 14px rgba(0, 0, 0, 0.06);\r\n         transition: .3s ease;\r\n         display: flex;\r\n         flex-direction: column;\r\n      }\r\n\r\n      .card:hover {\r\n         transform: translateY(-5px);\r\n         box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);\r\n      }\r\n\r\n      /* IMAGE */\r\n\r\n      .image-container {\r\n         position: relative;\r\n         width: 100%;\r\n         aspect-ratio: 1/1;\r\n         overflow: hidden;\r\n         cursor: pointer;\r\n      }\r\n\r\n      .image-container img {\r\n         position: absolute;\r\n         width: 100%;\r\n         height: 100%;\r\n         object-fit: cover;\r\n         opacity: 0;\r\n         transition: opacity .25s ease;\r\n      }\r\n\r\n      .image-container img.active {\r\n         opacity: 1;\r\n      }\r\n\r\n      /* ARROWS */\r\n\r\n      .arrow {\r\n         position: absolute;\r\n         top: 50%;\r\n         transform: translateY(-50%);\r\n         width: 28px;\r\n         height: 28px;\r\n         border-radius: 50%;\r\n         background: rgba(255, 255, 255, 0.9);\r\n         display: flex;\r\n         align-items: center;\r\n         justify-content: center;\r\n         cursor: pointer;\r\n         font-size: 14px;\r\n         font-weight: bold;\r\n         opacity: 0;\r\n         transition: .2s ease;\r\n         z-index: 5;\r\n      }\r\n\r\n      .card:hover .arrow {\r\n         opacity: 1;\r\n      }\r\n\r\n      .arrow:hover {\r\n         background: black;\r\n         color: white;\r\n      }\r\n\r\n      .arrow.left {\r\n         left: 8px;\r\n      }\r\n\r\n      .arrow.right {\r\n         right: 8px;\r\n      }\r\n\r\n      /* CONTENT */\r\n\r\n      .card-content {\r\n         padding: 14px;\r\n         display: flex;\r\n         flex-direction: column;\r\n         gap: 6px;\r\n      }\r\n\r\n      .card-title {\r\n         font-weight: 600;\r\n         font-size: 14px;\r\n      }\r\n\r\n      .review {\r\n         font-size: 12px;\r\n         color: #777;\r\n      }\r\n\r\n      .dimensions {\r\n         font-size: 12.5px;\r\n         color: #000000;\r\n      }\r\n\r\n      /* SKU BOX */\r\n\r\n      .sku-box {\r\n         display: inline-block;\r\n         margin-top: 0px;\r\n         padding: 2px 6px;\r\n         font-size: 11px;\r\n         border-radius: 999px;\r\n         background: #ffffff;\r\n         border: 1px solid #dddddd;\r\n         color: #444;\r\n         font-weight: 500;\r\n         width: fit-content;\r\n      }\r\n\r\n      .features {\r\n         font-size: 11px;\r\n         color: #4a4a4a;\r\n         margin-top: 4px;\r\n      }\r\n\r\n      .price {\r\n         font-size: 16px;\r\n         font-weight: 600;\r\n         color: black;\r\n         margin-top: 6px;\r\n      }\r\n\r\n      /* PAGINATION */\r\n\r\n      .pagination {\r\n         margin-top: 40px;\r\n         display: flex;\r\n         justify-content: center;\r\n         gap: 8px;\r\n         flex-wrap: wrap;\r\n      }\r\n\r\n      .page-btn {\r\n         padding: 6px 12px;\r\n         border-radius: 6px;\r\n         border: 1px solid #ccc;\r\n         background: white;\r\n         cursor: pointer;\r\n         font-size: 13px;\r\n      }\r\n\r\n      .page-btn.active {\r\n         background: black;\r\n         color: white;\r\n      }\r\n   </style>\r\n</head>\r\n\r\n<body>\r\n\r\n   <div class=\"collection-wrapper\">\r\n\r\n      <div class=\"collection-title\">Our Cabinet Collection</div>\r\n\r\n      <div class=\"controls\">\r\n\r\n         <div>\r\n            Filter by Size:\r\n            <select id=\"sizeFilter\">\r\n<option value=\"all\">All Sizes</option>\r\n</select>\r\n         </div>\r\n\r\n         <div>\r\n            Sort by Price:\r\n            <select id=\"priceSort\">\r\n<option value=\"default\">Default</option>\r\n<option value=\"low\">Low to High</option>\r\n<option value=\"high\">High to Low</option>\r\n</select>\r\n         </div>\r\n\r\n      </div>\r\n\r\n      <div class=\"collection-grid\" id=\"collectionGrid\"></div>\r\n      <div class=\"pagination\" id=\"pagination\"></div>\r\n\r\n   </div>\r\n\r\n   <script>\r\n      /* ===============================\r\n   EDIT PRODUCTS HERE\r\n   =============================== */\r\n\r\nconst products=[\r\n\r\n{\r\ntitle:\"Mallorca White Shaker <br>Standard Wall Cabinet 15\\\"\",\r\nsize:15,\r\nheight:36,\r\ndepth:12,\r\nsku:\"ICWS-W1536\",\r\nprice:277.03,\r\nreview:\"4.9/5\",\r\nfeatures:\"3 Adjustable Shelves | 1 Door\",\r\nlink:\"https://www.pkcabinet.com/products/white-shaker-15w-%C3%97-36h-standard-wall-cabinet-1-door-3-adjustable-shelves\",\r\nimages:[\r\n\"https://img-va.myshopline.com/image/store/1736838390436/imageName1772500816336_990x.png?w=1200&h=1200&q=100\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/imageName1772500821209_990x.png?w=1200&h=1200&q=100\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/W1523-(1)_990x.jpg?w=1200&h=1200&q=100\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/W1536-SHAKER-SIZE-(2)_990x.jpg?w=1200&h=1600&q=100\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/-1-9_990x.jpg?w=1200&h=694&q=100\"\r\n]\r\n},\r\n\r\n{\r\ntitle:\"Mallorca White Shaker <br>Drawer Base Cabinet 36\\\"\",\r\nsize:36,\r\nheight:34.5,\r\ndepth:24,\r\nsku:\"ICWS-2DB36\",\r\nprice:853.32,\r\nreview:\"4.8/5\",\r\nfeatures:\"2 Doors\",\r\nlink:\"https://www.pkcabinet.com/products/white-shaker-36w-drawer-base-cabinet-2-drawers\",\r\nimages:[\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker-(2).jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker-(3).jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker.jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-SHAKER-SIZE.jpg?w=1200&h=1600\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/-1-9.jpg?w=1200&h=694\"\r\n]\r\n},\r\n\r\n{\r\ntitle:\"Mallorca White Shaker <br>Drawer Base Cabinet 36\\\"\",\r\nsize:36,\r\nheight:34.5,\r\ndepth:24,\r\nsku:\"ICWS-2DB36\",\r\nprice:853.32,\r\nreview:\"4.8/5\",\r\nfeatures:\"2 Doors\",\r\nlink:\"https://www.pkcabinet.com/products/white-shaker-36w-drawer-base-cabinet-2-drawers\",\r\nimages:[\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker-(2).jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker-(3).jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker.jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-SHAKER-SIZE.jpg?w=1200&h=1600\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/-1-9.jpg?w=1200&h=694\"\r\n]\r\n},\r\n\r\n{\r\ntitle:\"Mallorca White Shaker <br>Drawer Base Cabinet 36\\\"\",\r\nsize:36,\r\nheight:34.5,\r\ndepth:24,\r\nsku:\"ICWS-2DB36\",\r\nprice:853.32,\r\nreview:\"4.8/5\",\r\nfeatures:\"2 Doors\",\r\nlink:\"https://www.pkcabinet.com/products/white-shaker-36w-drawer-base-cabinet-2-drawers\",\r\nimages:[\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker-(2).jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker-(3).jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker.jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-SHAKER-SIZE.jpg?w=1200&h=1600\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/-1-9.jpg?w=1200&h=694\"\r\n]\r\n},\r\n\r\n{\r\ntitle:\"Mallorca White Shaker <br>Drawer Base Cabinet 36\\\"\",\r\nsize:36,\r\nheight:34.5,\r\ndepth:24,\r\nsku:\"ICWS-2DB36\",\r\nprice:853.32,\r\nreview:\"4.8/5\",\r\nfeatures:\"2 Drawers\",\r\nlink:\"https://www.pkcabinet.com/products/white-shaker-36w-drawer-base-cabinet-2-drawers\",\r\nimages:[\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker-(2).jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker-(3).jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-white-shaker.jpg?w=2000&h=2000\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/2DB36-SHAKER-SIZE.jpg?w=1200&h=1600\",\r\n\"https://img-va.myshopline.com/image/store/1736838390436/-1-9.jpg?w=1200&h=694\"\r\n]\r\n}\r\n\r\n];\r\n\r\n/* ===============================\r\n   !!!DO NOT EDIT BELOW!!!\r\n   =============================== */\r\n\r\nconst grid=document.getElementById(\"collectionGrid\");\r\nconst pagination=document.getElementById(\"pagination\");\r\nconst sizeFilter=document.getElementById(\"sizeFilter\");\r\nconst priceSort=document.getElementById(\"priceSort\");\r\n\r\nconst uniqueSizes=[...new Set(products.map(p=>p.size))];\r\n\r\nuniqueSizes.forEach(size=>{\r\nconst opt=document.createElement(\"option\");\r\nopt.value=size;\r\nopt.textContent=size+'\"';\r\nsizeFilter.appendChild(opt);\r\n});\r\n\r\nlet currentPage=1;\r\nconst perPage=15;\r\n\r\nfunction renderProducts(){\r\n\r\nlet filtered=[...products];\r\n\r\nif(sizeFilter.value!==\"all\"){\r\nfiltered=filtered.filter(p=>p.size==sizeFilter.value);\r\n}\r\n\r\nif(priceSort.value===\"low\"){\r\nfiltered.sort((a,b)=>a.price-b.price);\r\n}\r\n\r\nif(priceSort.value===\"high\"){\r\nfiltered.sort((a,b)=>b.price-a.price);\r\n}\r\n\r\nconst totalPages=Math.ceil(filtered.length/perPage);\r\n\r\nif(currentPage>totalPages) currentPage=1;\r\n\r\nconst start=(currentPage-1)*perPage;\r\nconst paginated=filtered.slice(start,start+perPage);\r\n\r\ngrid.innerHTML=\"\";\r\n\r\npaginated.forEach(product=>{\r\n\r\nconst card=document.createElement(\"div\");\r\ncard.className=\"card\";\r\n\r\nconst imagesHTML=product.images.map((img,index)=>`\r\n<img src=\"${img}\" class=\"${index===0?'active':''}\">\r\n`).join(\"\");\r\n\r\ncard.innerHTML=`\r\n\r\n<div class=\"image-container\">\r\n\r\n${imagesHTML}\r\n\r\n<div class=\"arrow left\">&#10094;</div>\r\n<div class=\"arrow right\">&#10095;</div>\r\n\r\n</div>\r\n\r\n<div class=\"card-content\">\r\n\r\n<div class=\"card-title\">${product.title}</div>\r\n\r\n<div class=\"review\">${product.review}</div>\r\n<div class=\"dimensions\"> ${product.size}\" W x ${product.height}\" H x ${product.depth}\" D </div>\r\n\r\n<div class=\"sku-box\">SKU: ${product.sku}</div>\r\n<div class=\"features\">${product.features}</div>\r\n<div class=\"price\">$${product.price}</div>\r\n\r\n</div>\r\n\r\n</div>\r\n`;\r\n\r\nconst imgs=card.querySelectorAll(\"img\");\r\nconst left=card.querySelector(\".left\");\r\nconst right=card.querySelector(\".right\");\r\nconst imageBox=card.querySelector(\".image-container\");\r\n\r\nlet index=0;\r\n\r\nfunction showImage(i){\r\nimgs.forEach(img=>img.classList.remove(\"active\"));\r\nimgs[i].classList.add(\"active\");\r\n}\r\n\r\ncard.addEventListener(\"mouseenter\",()=>{\r\nif(imgs.length>1){\r\nindex=1;\r\nshowImage(index);\r\n}\r\n});\r\n\r\ncard.addEventListener(\"mouseleave\",()=>{\r\nindex=0;\r\nshowImage(index);\r\n});\r\n\r\nleft.addEventListener(\"click\",(e)=>{\r\ne.stopPropagation();\r\nindex=(index-1+imgs.length)%imgs.length;\r\nshowImage(index);\r\n});\r\n\r\nright.addEventListener(\"click\",(e)=>{\r\ne.stopPropagation();\r\nindex=(index+1)%imgs.length;\r\nshowImage(index);\r\n});\r\n\r\n/* IMAGE CLICK LINK ONLY */\r\n\r\nimageBox.addEventListener(\"click\",()=>{\r\nwindow.location.href=product.link;\r\n});\r\n\r\ngrid.appendChild(card);\r\n\r\n});\r\n\r\nrenderPagination(totalPages);\r\n}\r\n\r\nfunction renderPagination(totalPages){\r\n\r\npagination.innerHTML=\"\";\r\n\r\nfor(let i=1;i<=totalPages;i++){\r\n\r\nconst btn=document.createElement(\"div\");\r\n\r\nbtn.className=\"page-btn\";\r\n\r\nif(i===currentPage) btn.classList.add(\"active\");\r\n\r\nbtn.textContent=i;\r\n\r\nbtn.onclick=()=>{\r\n\r\ncurrentPage=i;\r\n\r\nrenderProducts();\r\n\r\nwindow.scrollTo({top:0,behavior:'smooth'});\r\n\r\n};\r\n\r\npagination.appendChild(btn);\r\n\r\n}\r\n\r\n}\r\n\r\nsizeFilter.addEventListener(\"change\",()=>{currentPage=1;renderProducts();});\r\npriceSort.addEventListener(\"change\",()=>{renderProducts();});\r\n\r\nrenderProducts();\r\n\r\n   </script>\r\n\r\n</body>\r\n\r\n</html>",
        "padding_top": 0,
        "padding_bottom": 0,
        "color_scheme": "none"
      },
      "blocks": {},
      "block_order": [],
      "custom_css": []
    }
  },
