      "blocks": {
        "1740135448652e298540": {
          "type": "heading",
          "settings": {
            "heading": "<strong>Our current delivery timeframe is 6-8 weeks nationwide.</strong>",
            "heading_size": "title3"
          },
          "blockId": "1740135448652e298540"
        },
        "1740135448652d73f2ae": {
          "type": "text",
          "settings": {
            "text": "<p>At pkcabinet.com, we are committed to delivering you high-quality kitchen cabinets at industry-leading delivery time frames. All qualifying orders will receive a final mile delivery service at no additional charge. Some restrictions may apply in select areas. <strong>Orders over $3,500 qualify for FREE shipping.</strong></p>"
          },
          "blockId": "1740135448652d73f2ae",
          "custom_css": []
        }
      },
      "block_order": [
        "1740135448652e298540",
        "1740135448652d73f2ae"
      ],
      "custom_css": []
    },
    "1740135989391ad0a687": {
      "disabled": false,
      "type": "collapsible-content",
      "settings": {
        "heading": "FAQ",
        "heading_size": "title3",
        "heading_alignment": "center",
        "layout_style": "none",
        "background_color": "rgba(0,0,0,0)",
        "color_scheme": "none",
        "open_first_collapsible_row": false,
        "image_ratio": "adapt",
        "desktop_layout": "image_second",
        "padding_top": 80,
        "padding_bottom": 80,
        "image": {}
      },
      "blocks": {
        "1740135989391a699646": {
          "type": "collapsible_row",
          "settings": {
            "heading": "When will my cabinets be delivered?",
            "icon": "apple",
            "icon_width": 18,
            "row_content": "At Cabinets.com, we are committed to delivering you high-quality kitchen cabinets at industry-leading delivery time frames. Lead times can vary by location. Your delivery date will depend on the Final Mile delivery facility’s availability, and the delivery agent will call you after they receive the cabinet order to schedule your appointment. The delivery agent will try to accommodate as best they can to schedule a convenient delivery date.",
            "page": ""
          },
          "blockId": "1740135989391a699646"
        },
        "1740135989391ff7f22b": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is the transit time from when my order is shipped to the Final Mile delivery facility?",
            "icon": "banana",
            "icon_width": 18,
            "row_content": "We usually say to allow for one to two weeks for transit and delivery.",
            "page": ""
          },
          "blockId": "1740135989391ff7f22b"
        },
        "17401359893915114ea1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How much time do I have to accept my order once it arrives at the Final Mile delivery facility?",
            "icon": "bottle",
            "icon_width": 18,
            "row_content": "All orders should be accepted as soon as possible, and our team of delivery professionals will contact you to schedule the earliest available dates.",
            "page": ""
          },
          "blockId": "17401359893915114ea1"
        },
        "174013598939193ecfba": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How quickly can the Final Mile delivery facility deliver my order?",
            "icon": "carrot",
            "icon_width": 18,
            "row_content": "Generally, the agent can deliver within a week of receiving the order.",
            "upload_icon": null,
            "page": ""
          },
          "blockId": "174013598939193ecfba"
        },
        "1742199497825dded701": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Will I be notified when my order ships?",
            "icon": "chat_bubble",
            "icon_width": 18,
            "row_content": "Yes, we will send you an email with the arrival date to the Final Mile facility along with more details regarding the delivery process once your order ships."
          }
        }
      },
