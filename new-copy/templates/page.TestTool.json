    "177177452250360baa04": {
      "disabled": false,
      "type": "custom-html",
      "settings": {
        "html": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n<title>Kitchen Layout Builder</title>\r\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap\" rel=\"stylesheet\">\r\n\r\n<style>\r\nhtml, body {\r\n    margin:0;\r\n    padding:0;\r\n    overflow-x:hidden;\r\n}\r\n\r\nbody {\r\n    font-family:'Poppins',sans-serif;\r\n    background:#f4f4f4;\r\n    display:flex;\r\n    flex-direction:column;\r\n    align-items:center;\r\n}\r\n\r\nh1 { margin:20px 0 10px; }\r\n\r\n.controls {\r\n    display:flex;\r\n    gap:10px;\r\n    margin-bottom:20px;\r\n    flex-wrap:wrap;\r\n    justify-content:center;\r\n}\r\n\r\nselect, button {\r\n    padding:10px 15px;\r\n    font-size:14px;\r\n    border-radius:6px;\r\n    border:1px solid #ccc;\r\n    cursor:pointer;\r\n}\r\n\r\n.workspace-wrapper {\r\n    width:100%;\r\n    display:flex;\r\n    justify-content:center;\r\n    overflow:hidden;\r\n}\r\n\r\n.workspace {\r\n    width:1080px; /* 10% smaller */\r\n    max-width:100%;\r\n    height:585px; /* 10% smaller */\r\n    background:#212121;\r\n    border:6px solid #000;\r\n    position:relative;\r\n    overflow:hidden;\r\n    cursor:grab;\r\n}\r\n\r\n.canvas {\r\n    position:absolute;\r\n    transform-origin:0 0;\r\n}\r\n\r\n/* Shared */\r\n.cabinet, .wall {\r\n    position:absolute;\r\n    box-sizing:border-box;\r\n    display:flex;\r\n    align-items:center;\r\n    justify-content:center;\r\n    font-weight:600;\r\n    user-select:none;\r\n    transform-origin:center center;\r\n}\r\n\r\n.cabinet {\r\n    background:#C69C6D;\r\n    border:3px solid #8B5A2B;\r\n    border-radius:4px;\r\n    color:#333;\r\n}\r\n\r\n.wall {\r\n    background:#A0A0A0;\r\n    border:4px solid #7A7A7A;\r\n    border-radius:2px;\r\n}\r\n\r\n.canvas .selected {\r\n    outline:3px dashed #fff;\r\n}\r\n\r\n/* ROTATE HANDLE */\r\n.rotate-handle {\r\n    position:absolute;\r\n    width:28px;\r\n    height:28px;\r\n    background:#fff;\r\n    border:2px solid #000;\r\n    border-radius:50%;\r\n    top:-40px;\r\n    left:50%;\r\n    transform:translateX(-50%);\r\n    cursor:grab;\r\n    display:none; /* hidden by default */\r\n    align-items:center;\r\n    justify-content:center;\r\n    font-size:16px;\r\n    font-weight:bold;\r\n    color:#000;\r\n    z-index:20;\r\n}\r\n\r\n/* Only visible when selected */\r\n.canvas .selected .rotate-handle {\r\n    display:flex;\r\n}\r\n\r\n/* Resize Handles */\r\n.resize-handle {\r\n    position:absolute;\r\n    width:12px;\r\n    height:12px;\r\n    background:#fff;\r\n    border:2px solid #000;\r\n    z-index:20;\r\n    display:none;\r\n}\r\n\r\n.canvas .wall.selected .resize-handle {\r\n    display:block;\r\n}\r\n\r\n.resize-right {\r\n    right:-8px;\r\n    top:50%;\r\n    transform:translateY(-50%);\r\n    cursor:ew-resize;\r\n}\r\n\r\n.resize-bottom {\r\n    bottom:-8px;\r\n    left:50%;\r\n    transform:translateX(-50%);\r\n    cursor:ns-resize;\r\n}\r\n</style>\r\n</head>\r\n\r\n<body>\r\n\r\n<h1>Kitchen Layout Builder</h1>\r\n\r\n<div class=\"controls\">\r\n<select id=\"cabinetSize\">\r\n<option value=\"9\">9\"</option>\r\n<option value=\"12\">12\"</option>\r\n<option value=\"15\">15\"</option>\r\n<option value=\"18\">18\"</option>\r\n<option value=\"21\">21\"</option>\r\n<option value=\"24\">24\"</option>\r\n<option value=\"27\">27\"</option>\r\n<option value=\"30\">30\"</option>\r\n<option value=\"33\">33\"</option>\r\n<option value=\"36\">36\"</option>\r\n<option value=\"39\">39\"</option>\r\n<option value=\"42\">42\"</option>\r\n<option value=\"45\">45\"</option>\r\n<option value=\"48\">48\"</option>\r\n</select>\r\n<button id=\"addCabinetBtn\">Add Cabinet</button>\r\n<button id=\"addWallBtn\">Add Wall</button>\r\n<button id=\"deleteBtn\">Delete</button>\r\n</div>\r\n\r\n<div class=\"workspace-wrapper\">\r\n<div class=\"workspace\" id=\"workspace\">\r\n<div class=\"canvas\" id=\"canvas\"></div>\r\n</div>\r\n</div>\r\n\r\n<script>\r\nconst canvas=document.getElementById(\"canvas\");\r\nconst workspace=document.getElementById(\"workspace\");\r\nconst addCabinetBtn=document.getElementById(\"addCabinetBtn\");\r\nconst addWallBtn=document.getElementById(\"addWallBtn\");\r\nconst deleteBtn=document.getElementById(\"deleteBtn\");\r\n\r\nconst scaleFactor=2;\r\nconst WALL_MIN_HEIGHT=9*scaleFactor;\r\n\r\nlet selectedElement=null;\r\nlet zoom=1, panX=0, panY=0;\r\nlet dragData=null;\r\nlet rotationData=null;\r\nlet resizeData=null;\r\nlet isPanning=false;\r\nlet panStartX=0, panStartY=0;\r\n\r\nfunction updateTransform(){\r\n    canvas.style.transform=`translate(${panX}px,${panY}px) scale(${zoom})`;\r\n}\r\n\r\nfunction screenToCanvas(x,y){\r\n    const rect=canvas.getBoundingClientRect();\r\n    return {\r\n        x:(x-rect.left)/zoom,\r\n        y:(y-rect.top)/zoom\r\n    };\r\n}\r\n\r\nfunction getCenter(el){\r\n    const rect=el.getBoundingClientRect();\r\n    const canvasRect=canvas.getBoundingClientRect();\r\n    return {\r\n        x:(rect.left-canvasRect.left+rect.width/2)/zoom,\r\n        y:(rect.top-canvasRect.top+rect.height/2)/zoom\r\n    };\r\n}\r\n\r\nworkspace.addEventListener(\"wheel\",function(e){\r\n    e.preventDefault();\r\n    const zoomAmount=0.1;\r\n    const direction=e.deltaY<0?1:-1;\r\n\r\n    const rect=workspace.getBoundingClientRect();\r\n    const mouseX=(e.clientX-rect.left-panX)/zoom;\r\n    const mouseY=(e.clientY-rect.top-panY)/zoom;\r\n\r\n    const newZoom=Math.min(Math.max(0.3,zoom+direction*zoomAmount),3);\r\n\r\n    panX-=mouseX*(newZoom-zoom);\r\n    panY-=mouseY*(newZoom-zoom);\r\n\r\n    zoom=newZoom;\r\n    updateTransform();\r\n},{passive:false});\r\n\r\nfunction createElement(width,height,isCabinet,label){\r\n    const el=document.createElement(\"div\");\r\n    el.classList.add(isCabinet?\"cabinet\":\"wall\");\r\n\r\n    el.style.width=width+\"px\";\r\n    el.style.height=height+\"px\";\r\n    el.style.left=\"300px\";\r\n    el.style.top=\"200px\";\r\n\r\n    if(label){\r\n        const span=document.createElement(\"span\");\r\n        span.innerText=label;\r\n        el.appendChild(span);\r\n    }\r\n\r\n    const rotateHandle=document.createElement(\"div\");\r\n    rotateHandle.classList.add(\"rotate-handle\");\r\n    rotateHandle.innerHTML=\"↻\";\r\n    el.appendChild(rotateHandle);\r\n\r\n    rotateHandle.onmousedown=function(e){\r\n        e.stopPropagation();\r\n        rotationData={\r\n            element:el,\r\n            center:getCenter(el)\r\n        };\r\n    };\r\n\r\n    if(!isCabinet){\r\n        const right=document.createElement(\"div\");\r\n        right.classList.add(\"resize-handle\",\"resize-right\");\r\n        const bottom=document.createElement(\"div\");\r\n        bottom.classList.add(\"resize-handle\",\"resize-bottom\");\r\n\r\n        el.appendChild(right);\r\n        el.appendChild(bottom);\r\n\r\n        right.onmousedown=function(e){\r\n            e.stopPropagation();\r\n            resizeData={\r\n                element:el,\r\n                type:\"width\",\r\n                startX:screenToCanvas(e.clientX,e.clientY).x,\r\n                startWidth:parseFloat(el.style.width)\r\n            };\r\n        };\r\n\r\n        bottom.onmousedown=function(e){\r\n            e.stopPropagation();\r\n            resizeData={\r\n                element:el,\r\n                type:\"height\",\r\n                startY:screenToCanvas(e.clientX,e.clientY).y,\r\n                startHeight:parseFloat(el.style.height)\r\n            };\r\n        };\r\n    }\r\n\r\n    attachCommonEvents(el);\r\n    canvas.appendChild(el);\r\n}\r\n\r\nfunction addCabinet(){\r\n    const w=parseInt(document.getElementById(\"cabinetSize\").value);\r\n    createElement(w*scaleFactor,24*scaleFactor,true,w+'\"');\r\n}\r\n\r\nfunction addWall(){\r\n    createElement(200,WALL_MIN_HEIGHT,false,null);\r\n}\r\n\r\ndocument.addEventListener(\"mousemove\",function(e){\r\n    const pos=screenToCanvas(e.clientX,e.clientY);\r\n\r\n    if(rotationData){\r\n        const dx=pos.x-rotationData.center.x;\r\n        const dy=pos.y-rotationData.center.y;\r\n        const angle=Math.atan2(dy,dx)*180/Math.PI+90;\r\n        rotationData.element.style.transform=`rotate(${angle}deg)`;\r\n\r\n        const span=rotationData.element.querySelector(\"span\");\r\n        if(span) span.style.transform=`rotate(${-angle}deg)`;\r\n        return;\r\n    }\r\n\r\n    if(resizeData){\r\n        if(resizeData.type===\"width\"){\r\n            resizeData.element.style.width=\r\n                (resizeData.startWidth+(pos.x-resizeData.startX))+\"px\";\r\n        }\r\n        if(resizeData.type===\"height\"){\r\n            resizeData.element.style.height=\r\n                Math.max(WALL_MIN_HEIGHT,\r\n                resizeData.startHeight+(pos.y-resizeData.startY))+\"px\";\r\n        }\r\n        return;\r\n    }\r\n\r\n    if(dragData){\r\n        dragData.element.style.left=(pos.x-dragData.offsetX)+\"px\";\r\n        dragData.element.style.top=(pos.y-dragData.offsetY)+\"px\";\r\n    }\r\n\r\n    if(isPanning){\r\n        panX=e.clientX-panStartX;\r\n        panY=e.clientY-panStartY;\r\n        updateTransform();\r\n    }\r\n});\r\n\r\ndocument.addEventListener(\"mouseup\",function(){\r\n    dragData=null;\r\n    rotationData=null;\r\n    resizeData=null;\r\n    isPanning=false;\r\n    workspace.style.cursor=\"grab\";\r\n});\r\n\r\nfunction attachCommonEvents(el){\r\n    el.onclick=function(e){\r\n        e.stopPropagation();\r\n\r\n        if(selectedElement===el){\r\n            el.classList.remove(\"selected\");\r\n            selectedElement=null;\r\n            return;\r\n        }\r\n\r\n        document.querySelectorAll(\"#canvas .cabinet,#canvas .wall\")\r\n            .forEach(c=>c.classList.remove(\"selected\"));\r\n\r\n        el.classList.add(\"selected\");\r\n        selectedElement=el;\r\n    };\r\n\r\n    el.onmousedown=function(e){\r\n        if(e.target.classList.contains(\"rotate-handle\") ||\r\n           e.target.classList.contains(\"resize-handle\")) return;\r\n\r\n        e.stopPropagation();\r\n        const pos=screenToCanvas(e.clientX,e.clientY);\r\n        dragData={\r\n            element:el,\r\n            offsetX:pos.x-parseFloat(el.style.left),\r\n            offsetY:pos.y-parseFloat(el.style.top)\r\n        };\r\n    };\r\n}\r\n\r\nworkspace.onmousedown=function(e){\r\n    if(e.target!==workspace) return;\r\n    isPanning=true;\r\n    panStartX=e.clientX-panX;\r\n    panStartY=e.clientY-panY;\r\n    workspace.style.cursor=\"grabbing\";\r\n};\r\n\r\ndeleteBtn.onclick=function(){\r\n    if(!selectedElement) return;\r\n    selectedElement.remove();\r\n    selectedElement=null;\r\n};\r\n\r\naddCabinetBtn.onclick=addCabinet;\r\naddWallBtn.onclick=addWall;\r\n\r\nupdateTransform();\r\n</script>\r\n\r\n</body>\r\n</html>",
        "padding_top": 60,
        "padding_bottom": 60,
        "color_scheme": "none"
      },
      "blocks": {},
      "block_order": [],
