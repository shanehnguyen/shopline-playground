      "blocks": {
        "174013704684042bf0cd": {
          "type": "title",
          "settings": {
            "title": "Why choose PK Cabinet?",
            "title_size": "medium"
          },
          "blockId": "174013704684042bf0cd",
          "custom_css": [],
          "sectionId": "1742207974480d620e0c",
          "canAddBlock": true,
          "formatName": "Why choose PK Cabinet?",
          "overLimit": true
        },
        "174013704684016328f8": {
          "type": "content",
          "settings": {
            "content": "<p><strong>- Quality and value at the same time</strong></p>\n<p>Every piece of cabinetry and bathroom fixture is carefully crafted to ensure exceptional quality standards. We pay attention to every detail and are committed to providing you with durable and beautiful solutions for your home.</p>\n<p><strong>- One-Stop Solutions</strong></p>\n<p>From design to installation, we offer a comprehensive kitchen and bathroom refurbishment service. Whether you're a DIY enthusiast or you're in the midst of a major home remodeling project, we offer professional support and efficient service to make every step of the process easy and enjoyable.</p>\n<p><strong>- Fast and affordable refurbishment services</strong></p>\n<p>Our services are not only efficient and fast but also cost-effective. Whether it's a home renovation or a commercial project, we can help you save time and money by completing your renovation quickly and cost-effectively.</p>"
          },
          "blockId": "174013704684016328f8",
          "sectionId": "1742207974480d620e0c",
          "canAddBlock": true,
          "formatName": "文本",
          "overLimit": true
        }
      },
