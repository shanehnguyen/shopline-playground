      "type": "custom-html",
      "settings": {
        "html": "<!DOCTYPE html>\r\n<html>\r\n\r\n<head>\r\n  <title>Cabinet Collections</title>\r\n\r\n  <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap\" rel=\"stylesheet\">\r\n\r\n  <style>\r\n    body {\r\n      margin: 0;\r\n      font-family: 'Poppins', sans-serif;\r\n      color: #2c2c2c;\r\n    }\r\n\r\n    /* SECTION */\r\n    .collections-section {\r\n      padding: 50px 8%;\r\n      background-color: #F3EFE8;\r\n    }\r\n\r\n    .section-title {\r\n      text-align: center;\r\n      font-size: 42px;\r\n      font-weight: 600;\r\n      margin-bottom: 70px;\r\n    }\r\n\r\n    /* GRID */\r\n    .collections-grid {\r\n      display: grid;\r\n      grid-template-columns: repeat(3, 1fr);\r\n      gap: 40px;\r\n      align-items: start;\r\n    }\r\n\r\n    /* CARD */\r\n    .collection-card {\r\n      position: relative;\r\n      background: white;\r\n      border-radius: 22px;\r\n      overflow: visible;\r\n      /* allow floating door to stay outside */\r\n      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);\r\n      cursor: pointer;\r\n      transition: transform 0.3s ease, box-shadow 0.3s ease;\r\n      align-self: start;\r\n    }\r\n\r\n    .collection-card:hover {\r\n      transform: translateY(-6px);\r\n      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);\r\n    }\r\n\r\n    /* IMAGE CONTAINER */\r\n    .image-container {\r\n      position: relative;\r\n      /* anchor for floating door */\r\n    }\r\n\r\n    .collection-card img.main-image {\r\n      width: 100%;\r\n      height: 260px;\r\n      object-fit: cover;\r\n      border-top-left-radius: 22px;\r\n      border-top-right-radius: 22px;\r\n    }\r\n\r\n    /* FLOATING CABINET DOOR */\r\n    .door-preview {\r\n      position: absolute;\r\n      top: 145px;\r\n      /* moved up 15px to avoid + icon */\r\n      right: 15px;\r\n      width: 80px;\r\n      height: 146px;\r\n      /* preserves 238x434 ratio */\r\n      object-fit: cover;\r\n      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);\r\n      background: white;\r\n      transition: transform 0.3s ease;\r\n      border-radius: 0px;\r\n      /* sharper edges for better visibility */\r\n    }\r\n\r\n    @media (max-width: 1000px) {\r\n      .door-preview {\r\n        top: 125px;\r\n        /* tablet */\r\n      }\r\n    }\r\n\r\n    @media (max-width: 600px) {\r\n      .door-preview {\r\n        top: 105px;\r\n        /* mobile */\r\n        width: 65px;\r\n        height: 119px;\r\n        /* preserves ratio */\r\n      }\r\n    }\r\n\r\n    /* HEADER */\r\n    .card-header {\r\n      padding: 25px;\r\n      font-size: 24px;\r\n      font-weight: 600;\r\n      display: flex;\r\n      justify-content: space-between;\r\n      align-items: center;\r\n      z-index: 2;\r\n      position: relative;\r\n    }\r\n\r\n    /* EXPAND ICON */\r\n    .expand-icon {\r\n      font-size: 22px;\r\n      transition: transform 0.3s ease;\r\n    }\r\n\r\n    /* SUBCATEGORY */\r\n    .subcategory-container {\r\n      height: 0;\r\n      overflow: hidden;\r\n      transition: height 0.4s ease;\r\n      padding: 0 25px;\r\n    }\r\n\r\n    .subcategories {\r\n      display: flex;\r\n      flex-wrap: wrap;\r\n      gap: 10px;\r\n      padding-bottom: 25px;\r\n    }\r\n\r\n    .subcategories a.subcategory-link {\r\n      display: inline-block;\r\n      text-decoration: none;\r\n      color: #2c2c2c;\r\n      background: #f0ece5;\r\n      padding: 8px 15px;\r\n      border-radius: 30px;\r\n      font-size: 13px;\r\n      font-weight: 500;\r\n      transition: background 0.3s ease;\r\n    }\r\n\r\n    .subcategories a.subcategory-link:hover {\r\n      background: #e2ddd5;\r\n    }\r\n\r\n    /* ACTIVE ICON */\r\n    .collection-card.active .expand-icon {\r\n      transform: rotate(45deg);\r\n    }\r\n\r\n    /* RESPONSIVE adjustments */\r\n    @media (max-width: 1000px) {\r\n      .collections-grid {\r\n        grid-template-columns: repeat(2, 1fr);\r\n      }\r\n\r\n      .door-preview {\r\n        top: 140px;\r\n        /* adjusted for tablet */\r\n      }\r\n    }\r\n\r\n    @media (max-width: 600px) {\r\n      .collections-grid {\r\n        grid-template-columns: 1fr;\r\n      }\r\n\r\n      .section-title {\r\n        font-size: 32px;\r\n      }\r\n\r\n      .door-preview {\r\n        top: 120px;\r\n        /* mobile */\r\n        width: 65px;\r\n        height: 119px;\r\n        /* preserves ratio */\r\n      }\r\n    }\r\n  </style>\r\n</head>\r\n\r\n<body>\r\n\r\n  <section class=\"collections-section\">\r\n    <h2 class=\"section-title\">Explore Our Collections</h2>\r\n\r\n    <div class=\"collections-grid\">\r\n\r\n      <!-- MALLORCA -->\r\n      <div class=\"collection-card\">\r\n        <div class=\"image-container\">\r\n          <img class=\"main-image\" src=\"https://img-va.myshopline.com/image/store/1736838390436/White-Shaker-frameless.jpg?w=1200&h=694\r\n\" alt=\"\">\r\n          <img class=\"door-preview\" src=\"https://img-va.myshopline.com/image/store/1736838390436/Mallorca-White-Door.png?w=238&h=434\r\n\" alt=\"Mallorca Door\">\r\n        </div>\r\n        <div class=\"card-header\">\r\n          Mallorca\r\n          <div class=\"expand-icon\">+</div>\r\n        </div>\r\n        <div class=\"subcategory-container\">\r\n          <div class=\"subcategories\">\r\n            <a href=\"https://www.pkcabinet.com/collections/mallorca-collection-white-shaker\"\r\n              class=\"subcategory-link\">White</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/mallorca-collection-dolphin-gray-shaker\"\r\n              class=\"subcategory-link\">Dolphin Gray</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n\r\n      <!-- SHADY -->\r\n      <div class=\"collection-card\">\r\n        <div class=\"image-container\">\r\n          <img class=\"main-image\" src=\"https://img-va.myshopline.com/image/store/1736838390436/Slim-White-Shaker-frameless-banner.jpg?w=1200&h=716\r\n\" alt=\"\">\r\n          <img class=\"door-preview\" src=\"https://img-va.myshopline.com/image/store/1736838390436/Shady-Slim-White-Door.png?w=238&h=434\" alt=\"Shady Door\">\r\n        </div>\r\n        <div class=\"card-header\">\r\n          Shady\r\n          <div class=\"expand-icon\">+</div>\r\n        </div>\r\n        <div class=\"subcategory-container\">\r\n          <div class=\"subcategories\">\r\n            <a href=\"https://www.pkcabinet.com/collections/shady-collection-slim-white-shaker\"\r\n              class=\"subcategory-link\">White</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/shady-collection-slim-gray-shaker\"\r\n              class=\"subcategory-link\">Gray</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/shady-collection-slim-natural-shaker\"\r\n              class=\"subcategory-link\">Natural</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n\r\n      <!-- FRANCO -->\r\n      <div class=\"collection-card\">\r\n        <div class=\"image-container\">\r\n          <img class=\"main-image\" src=\"https://img-va.myshopline.com/image/store/1736838390436/Franco-Collection-White-Shaker.jpg?w=1200&h=820\r\n\" alt=\"\">\r\n          <img class=\"door-preview\" src=\"https://img-va.myshopline.com/image/store/1736838390436/Franco-White-Door.png?w=238&h=434\r\n\" alt=\"Franco Door\">\r\n        </div>\r\n        <div class=\"card-header\">\r\n          Franco\r\n          <div class=\"expand-icon\">+</div>\r\n        </div>\r\n        <div class=\"subcategory-container\">\r\n          <div class=\"subcategories\">\r\n            <a href=\"https://www.pkcabinet.com/collections/franco-collection-white-shaker\"\r\n              class=\"subcategory-link\">White</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/franco-collection-gray-shaker\"\r\n              class=\"subcategory-link\">Gray</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/franco-collection-oak-shaker\"\r\n              class=\"subcategory-link\">Oak</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/franco-collection-slim-white-shaker\"\r\n              class=\"subcategory-link\">Slim White</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/franco-collection-slim-black-shaker\"\r\n              class=\"subcategory-link\">Slim Black</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/franco-collection-slim-oak-shaker\"\r\n              class=\"subcategory-link\">Slim Oak</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- IRENA -->\r\n      <div class=\"collection-card\">\r\n        <div class=\"image-container\">\r\n          <img class=\"main-image\" src=\"https://img-va.myshopline.com/image/store/1736838390436/Irena-Dual-jpg.jpg?w=1200&h=820\" alt=\"\">\r\n          <img class=\"door-preview\" src=\"https://img-va.myshopline.com/image/store/1736838390436/Irena-Dual-Door.png?w=238&h=434\" alt=\"Irena Door\">\r\n        </div>\r\n        <div class=\"card-header\">\r\n          Irena\r\n          <div class=\"expand-icon\">+</div>\r\n        </div>\r\n        <div class=\"subcategory-container\">\r\n          <div class=\"subcategories\">\r\n            <a href=\"https://www.pkcabinet.com/collections/irena-collection-white-dual-shaker\"\r\n              class=\"subcategory-link\">White</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/irena-collection-gray-dual-shaker\"\r\n              class=\"subcategory-link\">Gray</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/irena-collection-olive-dual-shaker\"\r\n              class=\"subcategory-link\">Olive</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/irena-collection-flat-glossy-white\"\r\n              class=\"subcategory-link\">Glossy White</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/irena-collection-flat-woodgrains\"\r\n              class=\"subcategory-link\">Woodgrains</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- NEWPORT -->\r\n      <div class=\"collection-card\">\r\n        <div class=\"image-container\">\r\n          <img class=\"main-image\" src=\"https://img-va.myshopline.com/image/store/1736838390436/Natural-Oak-banner.jpg?w=1200&h=718\r\n\" alt=\"\">\r\n          <img class=\"door-preview\" src=\"https://img-va.myshopline.com/image/store/1736838390436/Newport-Oak-DOor.png?w=238&h=434\r\n\" alt=\"Newport Door\">\r\n        </div>\r\n        <div class=\"card-header\">\r\n          Newport\r\n          <div class=\"expand-icon\">+</div>\r\n        </div>\r\n        <div class=\"subcategory-container\">\r\n          <div class=\"subcategories\">\r\n            <a href=\"https://www.pkcabinet.com/collections/newport-collection-natural-oak\"\r\n              class=\"subcategory-link\">Natural</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/newport-collection-umbria-elm\"\r\n              class=\"subcategory-link\">Umbria Elm</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/newport-collection-shoreline\"\r\n              class=\"subcategory-link\">Shoreline</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- ASPEN -->\r\n      <div class=\"collection-card\">\r\n        <div class=\"image-container\">\r\n          <img class=\"main-image\" src=\"https://img-va.myshopline.com/image/store/1736838390436/02ac86a99823438997284b7b2987da62.jpg?w=1200&h=720\r\n\" alt=\"\">\r\n          <img class=\"door-preview\" src=\"https://img-va.myshopline.com/image/store/1736838390436/Aspen-Stone-Gray-Door.png?w=238&h=434\r\n\" alt=\"Aspen Door\">\r\n        </div>\r\n        <div class=\"card-header\">\r\n          Aspen\r\n          <div class=\"expand-icon\">+</div>\r\n        </div>\r\n        <div class=\"subcategory-container\">\r\n          <div class=\"subcategories\">\r\n            <a href=\"https://www.pkcabinet.com/collections/aspen-collection-stone-gray-solids\"\r\n              class=\"subcategory-link\">Stone Gray</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/aspen-collection-emerald-solids\"\r\n              class=\"subcategory-link\">Emerald</a>\r\n            <a href=\"https://www.pkcabinet.com/collections/aspen-collection-raven-solids\"\r\n              class=\"subcategory-link\">Raven</a>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n\r\n\r\n    </div>\r\n  </section>\r\n\r\n  <script>\r\n    const cards = document.querySelectorAll(\".collection-card\");\r\n\r\ncards.forEach(card => {\r\n    const subContainer = card.querySelector('.subcategory-container');\r\n\r\n    card.addEventListener(\"click\", () => {\r\n        cards.forEach(c => {\r\n            if (c !== card) {\r\n                const otherSub = c.querySelector('.subcategory-container');\r\n                otherSub.style.height = '0';\r\n                c.classList.remove(\"active\");\r\n            }\r\n        });\r\n\r\n        if (card.classList.contains(\"active\")) {\r\n            subContainer.style.height = '0';\r\n        } else {\r\n            subContainer.style.height = subContainer.scrollHeight + 'px';\r\n        }\r\n\r\n        card.classList.toggle(\"active\");\r\n    });\r\n});\r\n  </script>\r\n\r\n</body>\r\n\r\n</html>",
