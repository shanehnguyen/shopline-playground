        "html": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n<title>Cabinet Collection</title>\r\n\r\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n\r\n<style>\r\nbody{\r\n  margin:0;\r\n  font-family:'Poppins',sans-serif;\r\n  background:#F3EFE8;\r\n}\r\n\r\n.collection-wrapper{\r\n  max-width:1150px;\r\n  margin:60px auto;\r\n  padding:0 clamp(20px,5vw,80px);\r\n}\r\n\r\n.collection-title{\r\n  text-align:center;\r\n  font-size:30px;\r\n  font-weight:600;\r\n  margin-bottom:30px;\r\n}\r\n\r\n.controls{\r\n  display:flex;\r\n  justify-content:space-between;\r\n  margin-bottom:24px;\r\n  flex-wrap:wrap;\r\n  gap:20px;\r\n}\r\n\r\n.controls select{\r\n  padding:8px 12px;\r\n  border-radius:8px;\r\n  border:1px solid #ccc;\r\n  font-family:'Poppins';\r\n  font-size:13px;\r\n}\r\n\r\n.collection-grid{\r\n  display:grid;\r\n  grid-template-columns:repeat(4,1fr);\r\n  gap:24px;\r\n}\r\n\r\n@media (max-width:1100px){\r\n  .collection-grid{\r\n    grid-template-columns:repeat(3,1fr);\r\n  }\r\n}\r\n\r\n@media (max-width:700px){\r\n  .collection-grid{\r\n    grid-template-columns:repeat(2,1fr);\r\n  }\r\n}\r\n\r\n.card{\r\n  background:#f4f4f4;\r\n  border-radius:16px;\r\n  overflow:hidden;\r\n  box-shadow:0 5px 14px rgba(0,0,0,0.06);\r\n  transition:.3s ease;\r\n  display:flex;\r\n  flex-direction:column;\r\n}\r\n\r\n.card:hover{\r\n  transform:translateY(-5px);\r\n  box-shadow:0 10px 24px rgba(0,0,0,0.12);\r\n}\r\n\r\n/* IMAGE */\r\n.image-container{\r\n  position:relative;\r\n  width:100%;\r\n  aspect-ratio:1/1;\r\n  overflow:hidden;\r\n  cursor:pointer;\r\n}\r\n\r\n.image-container img{\r\n  position:absolute;\r\n  width:100%;\r\n  height:100%;\r\n  object-fit:cover;\r\n  opacity:0;\r\n  transition:opacity .25s ease;\r\n}\r\n\r\n.image-container img.active{\r\n  opacity:1;\r\n}\r\n\r\n/* ARROWS */\r\n.arrow{\r\n  position:absolute;\r\n  top:50%;\r\n  transform:translateY(-50%);\r\n  width:28px;\r\n  height:28px;\r\n  border-radius:50%;\r\n  background:rgba(255,255,255,0.9);\r\n  display:flex;\r\n  align-items:center;\r\n  justify-content:center;\r\n  cursor:pointer;\r\n  font-size:14px;\r\n  font-weight:bold;\r\n  opacity:0;\r\n  transition:.2s ease;\r\n  z-index:5;\r\n}\r\n\r\n.card:hover .arrow{\r\n  opacity:1;\r\n}\r\n\r\n.arrow:hover{\r\n  background:black;\r\n  color:white;\r\n}\r\n\r\n.arrow.left{left:8px;}\r\n.arrow.right{right:8px;}\r\n\r\n/* CONTENT */\r\n.card-content {\r\n  padding: 14px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 6px;\r\n  flex: 1; \r\n}\r\n\r\n.card-title{\r\n  font-weight:600;\r\n  font-size:14px;\r\n}\r\n\r\n.card-title .subtitle {\r\n  display: block;    \r\n  font-size: 13px;     \r\n  font-weight: 400;    \r\n  color: #3d3d3d;     \r\n  line-height: 1.5;   \r\n  margin-top: 2px;    \r\n}\r\n\r\n.card-title span.white-shaker{\r\n  font-size:17px;\r\n}\r\n\r\n.dimensions{\r\n  font-size:12px;\r\n  color:#000000;\r\n}\r\n\r\n/* SKU BOX */\r\n.sku-box{\r\n  display:inline-block;\r\n  margin-top:0px;\r\n  padding:2px 6px;\r\n  font-size:11px;\r\n  border-radius:999px;\r\n  background:#ffffff;\r\n  border:1px solid #dddddd;\r\n  color:#444;\r\n  font-weight:400;\r\n  width:fit-content;\r\n}\r\n\r\n.features{\r\n  font-size:11px;\r\n  color:#4a4a4a;\r\n  margin-top:4px;\r\n}\r\n\r\n.price{\r\n  font-size:16px;\r\n  font-weight:600;\r\n  color:black;\r\n  margin-top:6px;\r\n}\r\n\r\n.price {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-top: auto; \r\n  font-size: 16px;\r\n  font-weight: 600;\r\n  color: black;\r\n}\r\n\r\n/* PAGINATION */\r\n.pagination{\r\n  margin-top:40px;\r\n  display:flex;\r\n  justify-content:center;\r\n  gap:8px;\r\n  flex-wrap:wrap;\r\n}\r\n\r\n.page-btn{\r\n  padding:6px 12px;\r\n  border-radius:6px;\r\n  border:1px solid #ccc;\r\n  background:white;\r\n  cursor:pointer;\r\n  font-size:13px;\r\n}\r\n\r\n.page-btn.active{\r\n  background:black;\r\n  color:white;\r\n}\r\n</style>\r\n</head>\r\n\r\n<body>\r\n\r\n<div class=\"collection-wrapper\">\r\n\r\n  <div class=\"collection-title\">Mallorca White Shakers</div>\r\n\r\n  <div class=\"controls\">\r\n    <div>\r\n      Filter by Size:\r\n      <select id=\"sizeFilter\">\r\n        <option value=\"all\">All Sizes</option>\r\n      </select>\r\n    </div>\r\n\r\n    <div>\r\n      Filter by Category:\r\n      <select id=\"categoryFilter\">\r\n        <option value=\"all\">All Categories</option>\r\n      </select>\r\n    </div>\r\n\r\n    <div>\r\n      Sort by Price:\r\n      <select id=\"priceSort\">\r\n        <option value=\"default\">Default</option>\r\n        <option value=\"low\">Low to High</option>\r\n        <option value=\"high\">High to Low</option>\r\n      </select>\r\n    </div>\r\n  </div>\r\n\r\n  <div class=\"collection-grid\" id=\"collectionGrid\"></div>\r\n  <div class=\"pagination\" id=\"pagination\"></div>\r\n\r\n</div>\r\n\r\n<script>\r\n\r\n// ===============================\r\n// PRODUCTS (first two only)\r\n// ===============================\r\nconst products=[\r\n  {\r\n    mainTitle: \"Mallorca White Shaker\",\r\n    subTitle: 'Bridge Wall Cabinet 36\"W × 12\"H',\r\n    size:36,\r\n    height:12,\r\n    depth:24,\r\n    sku:\"ICWS-W361224\",\r\n    price:303.51,\r\n    features:\"2 Doors\",\r\n    category:\"Wall Cabinet\",\r\n    link:\"https://www.pkcabinet.com/products/white-shaker-36w-%C3%97-12h-deep-24-wall-bridge-cabinet-2-doors\",\r\n    images:[\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/W361224-white-shaker-(2).jpg?w=1997&h=1997\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/W361224-white-shaker.jpg?w=1997&h=1997\",\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/W361224-SHAKER-SIZE.jpg?w=1200&h=1600\"\r\n    ]\r\n  },\r\n{\r\n    mainTitle:\