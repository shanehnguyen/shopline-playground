      "settings": {
        "html": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n<meta charset=\"UTF-8\">\r\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n\r\n<link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\r\n\r\n<style>\r\n\r\nbody{\r\n  margin:0;\r\n  font-family:'Poppins',sans-serif;\r\n  background:#F3EFE8;\r\n}\r\n\r\n\r\n/* ===== SPLIT LAYOUT ===== */\r\n\r\n.split{\r\n  display:flex;\r\n  width:100%;\r\n  height:100vh;\r\n  overflow:hidden;\r\n}\r\n\r\n\r\n/* LEFT IMAGE 2/5 */\r\n\r\n.left-image{\r\n  width:40%;\r\n  background:url(\"https://images.unsplash.com/photo-1600585154340-be6161a56a0c?q=80&w=1200\") center/cover no-repeat;\r\n}\r\n\r\n\r\n/* RIGHT CAROUSEL 3/5 */\r\n\r\n.right-carousel{\r\n  width:60%;\r\n  overflow:hidden;\r\n  position:relative;\r\n  display:flex;\r\n  align-items:center;\r\n}\r\n\r\n\r\n.carousel-track{\r\n  display:flex;\r\n  gap:24px;\r\n  transition:transform .4s ease;\r\n  padding:40px;\r\n}\r\n\r\n\r\n/* ===== CARD STYLE (UNCHANGED) ===== */\r\n\r\n.card{\r\n  width:260px;\r\n  background:#f4f4f4;\r\n  border-radius:16px;\r\n  overflow:hidden;\r\n  box-shadow:0 5px 14px rgba(0,0,0,0.06);\r\n  transition:.3s ease;\r\n  display:flex;\r\n  flex-direction:column;\r\n}\r\n\r\n.card:hover{\r\n  transform:translateY(-5px);\r\n  box-shadow:0 10px 24px rgba(0,0,0,0.12);\r\n}\r\n\r\n.image-container{\r\n  position:relative;\r\n  width:100%;\r\n  aspect-ratio:1/1;\r\n  overflow:hidden;\r\n  cursor:pointer;\r\n}\r\n\r\n.image-container img{\r\n  position:absolute;\r\n  width:100%;\r\n  height:100%;\r\n  object-fit:cover;\r\n  opacity:0;\r\n  transition:.25s;\r\n}\r\n\r\n.image-container img.active{\r\n  opacity:1;\r\n}\r\n\r\n.arrow{\r\n  position:absolute;\r\n  top:50%;\r\n  transform:translateY(-50%);\r\n  width:28px;\r\n  height:28px;\r\n  border-radius:50%;\r\n  background:white;\r\n  display:flex;\r\n  align-items:center;\r\n  justify-content:center;\r\n  cursor:pointer;\r\n  opacity:0;\r\n}\r\n\r\n.card:hover .arrow{\r\n  opacity:1;\r\n}\r\n\r\n.arrow.left{left:6px;}\r\n.arrow.right{right:6px;}\r\n\r\n.card-content{\r\n  padding:14px;\r\n  display:flex;\r\n  flex-direction:column;\r\n  gap:6px;\r\n}\r\n\r\n.card-title{\r\n  font-weight:600;\r\n  font-size:14px;\r\n}\r\n\r\n.subtitle{\r\n  font-size:13px;\r\n  color:#333;\r\n}\r\n\r\n.dimensions{\r\n  font-size:12px;\r\n}\r\n\r\n.sku-box{\r\n  font-size:11px;\r\n  border:1px solid #ccc;\r\n  padding:2px 6px;\r\n  border-radius:999px;\r\n  width:fit-content;\r\n  background:white;\r\n}\r\n\r\n.features{\r\n  font-size:11px;\r\n}\r\n\r\n.price{\r\n  font-weight:600;\r\n  margin-top:auto;\r\n}\r\n\r\n\r\n/* ARROWS */\r\n\r\n.big-arrow{\r\n  position:absolute;\r\n  top:50%;\r\n  transform:translateY(-50%);\r\n  font-size:30px;\r\n  cursor:pointer;\r\n  z-index:5;\r\n  user-select:none;\r\n}\r\n\r\n.big-left{ left:10px; }\r\n.big-right{ right:10px; }\r\n\r\n</style>\r\n</head>\r\n<body>\r\n\r\n\r\n<div class=\"split\">\r\n\r\n<div class=\"left-image\"></div>\r\n\r\n\r\n<div class=\"right-carousel\">\r\n\r\n<div class=\"big-arrow big-left\" onclick=\"move(-1)\">❮</div>\r\n<div class=\"big-arrow big-right\" onclick=\"move(1)\">❯</div>\r\n\r\n<div class=\"carousel-track\" id=\"track\"></div>\r\n\r\n</div>\r\n\r\n</div>\r\n\r\n\r\n<script>\r\n\r\n\r\n// =======================\r\n// PRODUCTS (UNCHANGED)\r\n// =======================\r\n\r\nconst products=[\r\n  {\r\n    mainTitle: \"Mallorca White Shaker\",\r\n    subTitle: 'Bridge Wall Cabinet 36\"W × 12\"H',\r\n    size:36,\r\n    height:12,\r\n    depth:24,\r\n    sku:\"ICWS-W361224\",\r\n    price:303.51,\r\n    features:\"2 Doors\",\r\n    category:\"Wall Cabinet\",\r\n    link:\"https://www.pkcabinet.com/products/white-shaker-36w-%C3%97-12h-deep-24-wall-bridge-cabinet-2-doors\",\r\n    images:[\r\n      \"https://img-va.myshopline.com/image/store/1736838390436/W361224-white-shaker-(2).jpg?w=1997&h=1997\",\r\