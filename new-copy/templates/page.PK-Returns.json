    "1775089058447a3c52d6": {
      "disabled": false,
      "type": "pk-refund-page",
      "settings": {
        "contact_heading": "Contact Information",
        "contact_email": "support@pkcabinet.com",
        "contact_phone": "562-625-6101",
        "business_hours": "Monday to Friday, 8:00 AM - 4:00 PM (PST)",
        "closing_quote": "We are committed to providing you with high-quality service. Thank you for your understanding and cooperation!"
      },
      "blocks": {
        "17750890584477f870b1": {
          "type": "policy_section",
          "settings": {
            "heading": "Conditions for Returns",
            "body": "1. Request Period: You may request a return within 14 days of receiving the item.\n\n2. Product Condition: Returned items must be unused, unassembled, and in the same condition as received. The packaging, accessories, and manuals must also be intact and in original condition.\n\n3. Damaged or Defective Items: If the product is damaged during shipping or has manufacturing defects, please contact us within 48 hours of receipt and provide photos as proof."
          },
          "blockId": "17750890584477f870b1"
        },
        "1775089058447f0bb861": {
          "type": "policy_section",
          "settings": {
            "heading": "Conditions for Exchanges",
            "body": "1. Request Period: Exchanges can be requested within 14 days of receiving the item.\n\n2. Eligible Items: The product must be unused, unassembled, and in its original condition with all packaging and components intact.\n\n3. Damaged or Defective Items: If you received a damaged or defective product and prefer an exchange instead of a return, please notify us within 48 hours of receiving the item, providing photos as proof.\n\n4. Product Availability: Exchanges are subject to product availability. If the requested replacement item is out of stock, we will assist with alternative solutions, such as a refund or selecting a similar product."
          },
          "blockId": "1775089058447f0bb861"
        },
        "17750890584472f17ecc": {
          "type": "policy_section",
          "settings": {
            "heading": "Returns Not Accepted",
            "body": "Items that have been assembled or used are not eligible. Damage caused by improper assembly due to failure to follow the instructions. Customized cabinets, including special sizes, colors, or configurations are non-returnable. Requests submitted after the return period will not be accepted."
          },
          "blockId": "17750890584472f17ecc"
        },
        "1775089058447a6f6027": {
          "type": "policy_section",
          "settings": {
            "heading": "Return Process",
            "body": "1. Contact Us: Please reach out to us via email or customer service with your purchase order number, product name and model, and reason for the return along with photos of the issue if applicable.\n\n2. Return Authorization: Once the return conditions are verified, we will provide a return authorization and the return address.\n\n3. Return the Item: For both returns and exchanges, please send the item back within 7 days after receiving the return authorization and provide the tracking number.\n\n4. Refund Process: For returns, once the item is received, inspected and approved, we will process your refund within 7-10 business days to the original payment method. For exchanges, the replacement item will be shipped once the returned item is received, inspected and approved."
          },
          "blockId": "1775089058447a6f6027"
        },
        "1775089058447a2cb22f": {
          "type": "policy_section",
          "settings": {
            "heading": "Return and Exchange Shipping Costs",
            "body": "For returns due to product defects or shipping damage, we will cover the return shipping costs. For returns due to personal reasons (e.g., change of mind or dissatisfaction with the product), the buyer is responsible for covering the return shipping costs."
          },
          "blockId": "1775089058447a2cb22f"
        }
      },
